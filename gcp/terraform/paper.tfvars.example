# trading-system/gcp/terraform/paper.tfvars.example
#
# Copy to paper.tfvars and fill in your values.
# paper.tfvars is in .gitignore — never commit real values.

project_id         = "your-gcp-project-id"
environment        = "paper"
region             = "asia-southeast1"
bigquery_dataset_id = "quantai_trading"
gcs_backup_bucket  = "quantai-backups-your-project-id"
alert_email        = "your-email@example.com"
