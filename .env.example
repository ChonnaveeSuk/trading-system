# trading-system/.env.example
#
# Template only — copy to .env and fill in values.
# .env is in .gitignore. NEVER commit real credentials.
#
# In Phase 1+: all secrets move to GCP Secret Manager.
# These env vars become fallbacks only (paper mode local dev).

# ── Trading mode ──────────────────────────────────────────────────────────────
# MUST be "paper" — never change to "live" without explicit authorization
TRADING_MODE=paper

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_before_running
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quantai
POSTGRES_USER=quantai

# DATABASE_URL must be set in your shell for cargo, pytest, CLI scripts,
# and Cloud Run jobs. There is no hardcoded fallback — production code
# fails loud when this is missing. Source .env then export, e.g.:
#   set -a && . .env && set +a
#   export DATABASE_URL="postgres://quantai:${POSTGRES_PASSWORD}@localhost:5432/quantai"
DATABASE_URL=postgres://quantai:change_me_before_running@localhost:5432/quantai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── IBKR TWS ──────────────────────────────────────────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497          # Paper trading port. Live = 7496. Never change here.
IBKR_CLIENT_ID=1

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-southeast1

# Service account key for local dev (never in production — use Workload Identity)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Rust logging ──────────────────────────────────────────────────────────────
RUST_LOG=info,quantai_core=debug
