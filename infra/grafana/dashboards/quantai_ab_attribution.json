    {
      "id": 203,
      "type": "barchart",
      "title": "Win Rate by signal_type (closed trades)",
      "datasource": {
        "type": "postgres",
        "uid": "quantai_pg"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "\nWITH ranked AS (\n  SELECT f.symbol, o.signal_type, f.side, f.fill_price,\n         ROW_NUMBER() OVER (PARTITION BY f.symbol, o.signal_type, f.side ORDER BY f.timestamp) AS rn\n  FROM fills f JOIN orders o ON f.client_order_id = o.client_order_id\n),\npairs AS (\n  SELECT b.signal_type,\n         CASE WHEN s.fill_price > b.fill_price THEN 1 ELSE 0 END AS win\n  FROM ranked b JOIN ranked s USING (symbol, signal_type, rn)\n  WHERE b.side='BUY' AND s.side='SELL'\n)\nSELECT signal_type AS \"Strategy\",\n       ROUND(100.0 * SUM(win)::numeric / NULLIF(COUNT(*), 0), 1)::float8 AS \"Win Rate %\",\n       COUNT(*)::bigint AS \"Trades\"\nFROM pairs GROUP BY signal_type ORDER BY signal_type\n",
          "format": "table"
        }
      ],
      "options": {
        "xField": "Strategy",
        "orientation": "vertical",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "fillOpacity": 80,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 40
              },
              {
                "color": "green",
                "value": 55
              }
            ]
          }
        }
      }
