          "rawSql": "\nSELECT signal_type AS \"Strategy\",\n       symbol AS \"Symbol\",\n       ROUND(quantity::numeric, 4)::float8 AS \"Quantity\",\n       ROUND(average_cost::numeric, 4)::float8 AS \"Avg Cost\",\n       ROUND(unrealized_pnl::numeric, 2)::float8 AS \"Unrealized P&L\",\n       stop_loss::float8 AS \"Stop Loss\",\n       opened_at AS \"Opened\"\nFROM positions\nWHERE quantity != 0\nORDER BY signal_type, opened_at DESC\n",
