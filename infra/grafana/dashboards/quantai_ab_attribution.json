    {
      "id": 201,
      "type": "timeseries",
      "title": "Cumulative Realized P&L by signal_type",
      "datasource": {
        "type": "postgres",
        "uid": "quantai_pg"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "\nWITH ranked AS (\n  SELECT f.symbol, o.signal_type, f.side, f.fill_price, f.filled_quantity, f.timestamp,\n         ROW_NUMBER() OVER (PARTITION BY f.symbol, o.signal_type, f.side ORDER BY f.timestamp) AS rn\n  FROM fills f JOIN orders o ON f.client_order_id = o.client_order_id\n),\npairs AS (\n  SELECT b.signal_type, s.timestamp AS sell_time,\n         (s.fill_price - b.fill_price) * LEAST(b.filled_quantity, s.filled_quantity) AS pnl\n  FROM ranked b JOIN ranked s USING (symbol, signal_type, rn)\n  WHERE b.side='BUY' AND s.side='SELL'\n),\ndaily AS (\n  SELECT date_trunc('day', sell_time)::timestamptz AS time,\n         COALESCE(SUM(pnl) FILTER (WHERE signal_type='momentum'),  0)::float8 AS mom,\n         COALESCE(SUM(pnl) FILTER (WHERE signal_type='trend_ride'), 0)::float8 AS tr\n  FROM pairs\n  GROUP BY 1\n)\nSELECT time,\n       SUM(mom) OVER (ORDER BY time) AS \"Momentum\",\n       SUM(tr)  OVER (ORDER BY time) AS \"Trend-Ride\"\nFROM daily ORDER BY time\n",
          "format": "time_series"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": true
          }
        }
      }
    },
    {
