          "rawSql": "\nSELECT date_trunc('day', f.timestamp)::timestamptz AS time,\n       COUNT(*) FILTER (WHERE o.signal_type='momentum')::bigint  AS \"Momentum\",\n       COUNT(*) FILTER (WHERE o.signal_type='trend_ride')::bigint AS \"Trend-Ride\"\nFROM fills f JOIN orders o USING (client_order_id)\nGROUP BY 1 ORDER BY 1\n",
