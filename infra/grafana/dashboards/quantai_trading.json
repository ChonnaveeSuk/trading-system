{
  "__inputs": [],
  "__requires": [
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Strategy Performance", "url": "/d/quantai-strategy-v1", "type": "link", "icon": "chart-line", "targetBlank": false },
    { "title": "System Health",        "url": "/d/quantai-health-v1",   "type": "link", "icon": "heart",      "targetBlank": false }
  ],
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Live Paper Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },

    {
      "id": 2,
      "type": "stat",
      "title": "90-Day Max Drawdown",
      "description": "Max peak-to-trough drawdown over last 90 days. Alert: yellow > 8%, red > 15%.",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "WITH vals AS (SELECT COALESCE(ending_value, starting_value) AS v FROM daily_pnl WHERE trading_date >= CURRENT_DATE - 90 ORDER BY trading_date), running AS (SELECT v, MAX(v) OVER (ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS peak FROM vals) SELECT COALESCE(ROUND(ABS(MIN((v - peak) / NULLIF(peak, 0) * 100.0))::numeric, 2), 0)::float8 AS \"Max DD %\" FROM running",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 8    },
              { "color": "red",    "value": 15   }
            ]
          }
        }
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Days in Paper Run",
      "description": "Trading days with recorded daily_pnl. Gate requires 90.",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*)::int AS \"Days\" FROM daily_pnl",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",   "value": null },
              { "color": "yellow", "value": 30   },
              { "color": "green",  "value": 90   }
            ]
          }
        }
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "BUY Signals Today",
      "description": "Number of BUY signals fired today",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*)::int AS \"BUY Today\" FROM signals WHERE created_at >= CURRENT_DATE AND direction = 'BUY'",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      }
    },

    {
      "id": 5,
      "type": "stat",
      "title": "SELL Signals Today",
      "description": "Number of SELL signals fired today",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*)::int AS \"SELL Today\" FROM signals WHERE created_at >= CURRENT_DATE AND direction = 'SELL'",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": { "steps": [{ "color": "red", "value": null }] }
        }
      }
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Total P&L (THB)",
      "description": "Realized P&L from all fills, converted to THB at 35.7",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(ROUND((SUM(realized_pnl) * 35.7)::numeric, 0), 0)::float8 AS \"Realized P&L (THB)\" FROM positions",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 0    }
            ]
          }
        }
      }
    },

    {
      "id": 7,
      "type": "stat",
      "title": "Trading Mode",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "SELECT 1::float8 AS \"Mode\" FROM system_metrics LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "PAPER", "color": "blue", "index": 0 }
              }
            }
          ]
        }
      }
    },

    {
      "id": 10,
      "type": "row",
      "title": "P&L Tracking (THB)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Daily P&L vs Target (THB)",
      "description": "Green bars = profitable day. Dashed line = 1,000 THB/day target. USD P&L × 35.7 THB/USD.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "SELECT trading_date AS time, (total_pnl * 35.7)::float8 AS \"Daily P&L (THB)\", 1000.0::float8 AS \"Target (1,000 THB)\" FROM daily_pnl ORDER BY trading_date",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80 },
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 0    }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Target (1,000 THB)" },
            "properties": [
              { "id": "custom.drawStyle",   "value": "line"  },
              { "id": "custom.lineWidth",   "value": 2       },
              { "id": "custom.fillOpacity", "value": 0       },
              { "id": "custom.lineStyle",   "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "color",              "value": { "mode": "fixed", "fixedColor": "orange" } },
              { "id": "custom.hideFrom",    "value": { "tooltip": false, "viz": false, "legend": false } }
            ]
          }
        ]
      }
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "Cumulative P&L since Paper Start (THB)",
      "description": "Running total of daily P&L in THB. USD × 35.7 THB/USD.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "SELECT trading_date AS time, (SUM(total_pnl) OVER (ORDER BY trading_date) * 35.7)::float8 AS \"Cumulative P&L (THB)\" FROM daily_pnl ORDER BY trading_date",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": {
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 0    }
            ]
          }
        }
      }
    },

    {
      "id": 20,
      "type": "row",
      "title": "Win Rate & Active Positions",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "collapsed": false
    },

    {
      "id": 21,
      "type": "gauge",
      "title": "Win Rate (Rolling 7 Days)",
      "description": "% of SELL fills in the last 7 days that closed above the most recent BUY price for that symbol. Target > 55%.",
      "gridPos": { "h": 10, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "WITH sells_7d AS (SELECT s.fill_price AS sell_price, (SELECT b.fill_price FROM fills b WHERE b.symbol = s.symbol AND b.side = 'BUY' AND b.timestamp < s.timestamp ORDER BY b.timestamp DESC LIMIT 1) AS buy_price FROM fills s WHERE s.side = 'SELL' AND s.timestamp >= NOW() - INTERVAL '7 days') SELECT COALESCE(ROUND(100.0 * COUNT(*) FILTER (WHERE sell_price > COALESCE(buy_price, 0)) / NULLIF(COUNT(*), 0), 1), 0)::float8 AS \"Win Rate 7d %\" FROM sells_7d",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizWidth": 75,
        "minVizHeight": 75
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 40   },
              { "color": "green",  "value": 55   }
            ]
          }
        }
      }
    },

    {
      "id": 22,
      "type": "table",
      "title": "Active Positions",
      "description": "Open positions with entry price and current P&L",
      "gridPos": { "h": 10, "w": 18, "x": 6, "y": 16 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "SELECT p.symbol AS \"Symbol\", CASE WHEN p.quantity > 0 THEN 'LONG' WHEN p.quantity < 0 THEN 'SHORT' ELSE 'FLAT' END AS \"Side\", p.quantity::float8 AS \"Qty\", p.average_cost::float8 AS \"Entry Price\", (p.average_cost * ABS(p.quantity))::float8 AS \"Position Value\", p.unrealized_pnl::float8 AS \"Unrealized P&L\", (p.unrealized_pnl * 35.7)::float8 AS \"Unreal P&L (THB)\", p.updated_at AS \"Updated\" FROM positions p WHERE p.quantity <> 0 ORDER BY ABS(p.unrealized_pnl) DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": { "footer": { "show": false } },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Entry Price"      }, "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 4 }] },
          { "matcher": { "id": "byName", "options": "Position Value"   }, "properties": [{ "id": "unit", "value": "currencyUSD" }] },
          { "matcher": { "id": "byName", "options": "Unrealized P&L"   }, "properties": [
            { "id": "unit",                  "value": "currencyUSD" },
            { "id": "custom.displayMode",    "value": "color-text"  },
            { "id": "thresholds",            "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] } }
          ]},
          { "matcher": { "id": "byName", "options": "Unreal P&L (THB)" }, "properties": [
            { "id": "decimals",              "value": 0             },
            { "id": "custom.displayMode",    "value": "color-text"  },
            { "id": "thresholds",            "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] } }
          ]},
          { "matcher": { "id": "byName", "options": "Side" }, "properties": [
            { "id": "custom.displayMode", "value": "color-background" },
            { "id": "mappings", "value": [
              { "type": "value", "options": { "LONG":  { "text": "LONG",  "color": "green", "index": 0 } } },
              { "type": "value", "options": { "SHORT": { "text": "SHORT", "color": "red",   "index": 1 } } }
            ]}
          ]}
        ]
      }
    },

    {
      "id": 30,
      "type": "row",
      "title": "90-Day Gate Tracking  |  Gate: Sharpe > 1.0 · MaxDD < 15%",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": false
    },

    {
      "id": 31,
      "type": "timeseries",
      "title": "Portfolio Equity Curve",
      "description": "Daily ending portfolio value from daily_pnl (starts at $100,000 USD paper).",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 27 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "SELECT trading_date AS time, COALESCE(ending_value, starting_value)::float8 AS \"Portfolio Value\" FROM daily_pnl ORDER BY trading_date",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },

    {
      "id": 32,
      "type": "timeseries",
      "title": "Drawdown from Peak",
      "description": "Daily % drawdown from the highest portfolio value reached. Gate: must stay above −15%.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 27 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "WITH vals AS (SELECT trading_date, COALESCE(ending_value, starting_value) AS v FROM daily_pnl), peaks AS (SELECT trading_date, v, MAX(v) OVER (ORDER BY trading_date ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS peak FROM vals) SELECT trading_date AS time, ROUND(100.0 * (v - peak) / NULLIF(peak, 0), 2)::float8 AS \"Drawdown %\" FROM peaks ORDER BY trading_date",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },

    {
      "id": 33,
      "type": "timeseries",
      "title": "Rolling 30-Day Sharpe Ratio",
      "description": "Annualised Sharpe over a 30-day rolling window of daily returns. Gate: must be > 1.0.",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 36 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "WITH port AS (SELECT trading_date, COALESCE(ending_value, starting_value) AS v FROM daily_pnl ORDER BY trading_date), rets AS (SELECT trading_date, (v - LAG(v) OVER (ORDER BY trading_date)) / NULLIF(LAG(v) OVER (ORDER BY trading_date), 0) AS r FROM port) SELECT trading_date AS time, ROUND((SQRT(252) * AVG(r) OVER (ORDER BY trading_date ROWS BETWEEN 29 PRECEDING AND CURRENT ROW) / NULLIF(STDDEV(r) OVER (ORDER BY trading_date ROWS BETWEEN 29 PRECEDING AND CURRENT ROW), 0))::numeric, 2)::float8 AS \"Sharpe (30d)\" FROM rets WHERE r IS NOT NULL ORDER BY trading_date",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "custom": { "lineWidth": 2 },
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "green",  "value": 1.0  }
            ]
          }
        }
      }
    },

    {
      "id": 34,
      "type": "stat",
      "title": "Unrealized P&L",
      "description": "Mark-to-market of all open positions",
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 36 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(SUM(unrealized_pnl), 0)::float8 AS \"Unrealized P&L\" FROM positions",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] }
        }
      }
    },

    {
      "id": 35,
      "type": "stat",
      "title": "Total P&L (Realized + Unrealized)",
      "description": "All fills P&L plus open-position mark-to-market",
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 36 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "SELECT COALESCE((SUM(realized_pnl) + SUM(unrealized_pnl))::float8, 0) AS \"Total P&L\" FROM positions",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] }
        }
      }
    },

    {
      "id": 36,
      "type": "stat",
      "title": "Total Fills",
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 40 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*)::int AS \"Total Fills\" FROM fills",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },

    {
      "id": 37,
      "type": "stat",
      "title": "Open Positions",
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 40 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*)::int AS \"Open Positions\" FROM positions WHERE quantity <> 0",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      }
    },

    {
      "id": 40,
      "type": "row",
      "title": "Recent Fills & Signals",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
      "collapsed": false
    },

    {
      "id": 41,
      "type": "table",
      "title": "Recent Fills (last 20)",
      "description": "Most recent fills from the paper trading engine",
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 45 },
      "datasource": { "type": "postgres", "uid": "quantai_pg" },
      "targets": [
        {
          "rawSql": "SELECT timestamp AS \"Time\", symbol AS \"Symbol\", side AS \"Side\", filled_quantity::float8 AS \"Qty\", fill_price::float8 AS \"Fill Price\", commission::float8 AS \"Commission\", gross_value::float8 AS \"Gross Value\", strategy_id AS \"Strategy\" FROM fills ORDER BY timestamp DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
